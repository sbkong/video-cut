<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VCut.Controls.TimeCodeBox"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <UserControl.Resources>
        <Style x:Key="TcField" TargetType="TextBox">
            <Setter Property="Width" Value="34" />
            <Setter Property="MaxLength" Value="2" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0,2" />
            <Setter Property="Background" Value="Transparent" />
        </Style>
        <Style x:Key="TcSep" TargetType="TextBlock">
            <Setter Property="Text" Value=":" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="Opacity" Value="0.6" />
        </Style>
    </UserControl.Resources>

    <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlElevationBorderBrush}" BorderThickness="1"
            CornerRadius="4" Padding="6,3">
        <StackPanel Orientation="Horizontal" Spacing="1" VerticalAlignment="Center">
            <TextBox x:Name="HourBox"   Style="{StaticResource TcField}" />
            <TextBlock Style="{StaticResource TcSep}" />
            <TextBox x:Name="MinuteBox" Style="{StaticResource TcField}" />
            <TextBlock Style="{StaticResource TcSep}" />
            <TextBox x:Name="SecondBox" Style="{StaticResource TcField}" />
            <TextBlock Style="{StaticResource TcSep}" />
            <TextBox x:Name="FrameBox"  Style="{StaticResource TcField}" />
        </StackPanel>
    </Border>
</UserControl>
