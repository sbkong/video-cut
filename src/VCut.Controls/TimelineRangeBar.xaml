<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VCut.Controls.TimelineRangeBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Canvas x:Name="Track" Background="Transparent"
                SizeChanged="OnTrackSizeChanged"
                PointerEntered="OnTrackEntered"
                PointerExited="OnTrackExited"
                PointerPressed="OnTrackPressed"
                PointerMoved="OnTrackMoved"
                PointerReleased="OnTrackReleased">

            <!-- 전체 트랙 -->
            <Border x:Name="Rail" Height="8" CornerRadius="2" Background="#3A3D42" />

            <!-- 재생 진행 (0 → Position) -->
            <Border x:Name="Progress" Height="8" CornerRadius="2,0,0,2"
                    Background="#3574F0" Opacity="0.38" />

            <!-- 선택 구간 (Start → End) -->
            <Border x:Name="Selection" Height="8" CornerRadius="0"
                    Background="#3574F0" Opacity="0.80" />

            <!-- 시작 핸들 -->
            <Border x:Name="StartHandle" Width="18" Height="18" CornerRadius="3"
                    Background="#3574F0" BorderBrush="#6AA0FF" BorderThickness="1"
                    ManipulationMode="None"
                    PointerPressed="OnHandlePressed"
                    PointerMoved="OnHandleMoved"
                    PointerReleased="OnHandleReleased">
                <Path Data="M0,0 L5,4.5 L0,9" Stroke="White" StrokeThickness="1.8"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <!-- 끝 핸들 -->
            <Border x:Name="EndHandle" Width="18" Height="18" CornerRadius="3"
                    Background="#3574F0" BorderBrush="#6AA0FF" BorderThickness="1"
                    ManipulationMode="None"
                    PointerPressed="OnHandlePressed"
                    PointerMoved="OnHandleMoved"
                    PointerReleased="OnHandleReleased">
                <Path Data="M5,0 L0,4.5 L5,9" Stroke="White" StrokeThickness="1.8"
                      StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                      HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>

            <!-- 재생헤드 -->
            <Grid x:Name="Playhead" Width="20" IsHitTestVisible="False">
                <!-- 넓은 히트 영역 -->
                <Rectangle Fill="Transparent" />
                <!-- 수직 선 -->
                <Rectangle Width="2" Fill="#F5A623" HorizontalAlignment="Center" />
                <!-- 역삼각형 헤드 -->
                <Path Data="M0,0 L16,0 L8,13 Z" Fill="#F5A623"
                      Width="16" Height="13" Stretch="Fill"
                      HorizontalAlignment="Center" VerticalAlignment="Top"
                      Margin="0,0,0,0" />
            </Grid>

            <!-- 호버 타임 툴팁 -->
            <Border x:Name="HoverTip" Visibility="Collapsed" IsHitTestVisible="False"
                    Background="#CC1B1D21" CornerRadius="3" Padding="5,2">
                <TextBlock x:Name="HoverTipText" Text="00:00:00.00" FontSize="10" Foreground="White" />
            </Border>

        </Canvas>
    </Grid>
</UserControl>
