<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VCut.Controls.TimelineRangeBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Height="54">
        <Canvas x:Name="Track" Background="Transparent" SizeChanged="OnTrackSizeChanged"
                PointerPressed="OnTrackPressed">

            <!-- 전체 길이 레일 -->
            <Border x:Name="Rail" Height="10" CornerRadius="5"
                    Background="{ThemeResource ControlStrongFillColorDefaultBrush}" />

            <!-- 선택 구간(파란색) -->
            <Border x:Name="Selection" Height="10" CornerRadius="5"
                    Background="#5A8CFF" Opacity="0.55" />

            <!-- 시작 핸들 -->
            <Border x:Name="StartHandle" Width="12" Height="30" CornerRadius="3"
                    Background="#5A8CFF" BorderBrush="White" BorderThickness="1"
                    ManipulationMode="TranslateX"
                    PointerPressed="OnHandlePressed" PointerMoved="OnHandleMoved" PointerReleased="OnHandleReleased" />

            <!-- 끝 핸들 -->
            <Border x:Name="EndHandle" Width="12" Height="30" CornerRadius="3"
                    Background="#5A8CFF" BorderBrush="White" BorderThickness="1"
                    ManipulationMode="TranslateX"
                    PointerPressed="OnHandlePressed" PointerMoved="OnHandleMoved" PointerReleased="OnHandleReleased" />

            <!-- 재생헤드(주황) -->
            <Rectangle x:Name="Playhead" Width="2" Height="40" Fill="#F5A623" />
        </Canvas>
    </Grid>
</UserControl>
