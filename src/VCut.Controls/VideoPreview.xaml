<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="VCut.Controls.VideoPreview"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="using:VCut.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid RowDefinitions="*,Auto" Background="{StaticResource BcAppBrush}">

        <!-- ── 영상 영역 ──────────────────────────────────────────────── -->
        <Border Grid.Row="0" Background="Black" CornerRadius="4,4,0,0">
            <MediaPlayerElement
                x:Name="Player"
                AreTransportControlsEnabled="False"
                AutoPlay="False"
                Stretch="Uniform"
                RenderTransformOrigin="0.5,0.5">
                <MediaPlayerElement.RenderTransform>
                    <CompositeTransform x:Name="PlayerTransform" />
                </MediaPlayerElement.RenderTransform>
            </MediaPlayerElement>
        </Border>

        <!-- ── 컨트롤 패널 ──────────────────────────────────────────── -->
        <Border Grid.Row="1"
                BorderBrush="{StaticResource BcDividerBrush}"
                BorderThickness="0,1,0,0">
            <Grid RowDefinitions="36,46,34"
                  Background="{StaticResource BcPanelDarkBrush}">

                <!-- ── Row 0: 트랜스포트 바 ──────────────────────────── -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto,*,Auto"
                      Padding="10,0"
                      Background="{StaticResource BcRailBrush}">

                    <!-- 타임코드 (좌) -->
                    <TextBlock Grid.Column="0" x:Name="PositionText"
                               Text="00:00:00.00 / 00:00:00.00"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource BcTextBrush}" />

                    <!-- 트랜스포트 버튼: 이전키프 · 이전프 · 재생 · 정지 · 다음프 · 다음키프 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="0">
                        <Button x:Name="PrevKeyframeButton" Click="OnPrevKeyframe"
                                Style="{StaticResource GlyphButtonStyle}"
                                ToolTipService.ToolTip="이전 키프레임 (Ctrl+←)">
                            <FontIcon Glyph="&#xE892;" FontSize="13" />
                        </Button>
                        <Button x:Name="PrevFrameButton" Click="OnPrevFrame"
                                Style="{StaticResource GlyphButtonStyle}"
                                ToolTipService.ToolTip="이전 프레임 (←)">
                            <FontIcon Glyph="&#xE76B;" FontSize="13" />
                        </Button>
                        <Button x:Name="PlayPauseButton" Click="OnPlayPause"
                                Style="{StaticResource GlyphButtonStyle}"
                                ToolTipService.ToolTip="재생/일시정지 (Space)">
                            <FontIcon x:Name="PlayIcon" Glyph="&#xE768;" FontSize="15" />
                        </Button>
                        <Button Click="OnStop" Style="{StaticResource GlyphButtonStyle}"
                                ToolTipService.ToolTip="정지">
                            <FontIcon Glyph="&#xE71A;" FontSize="13" />
                        </Button>
                        <Button x:Name="NextFrameButton" Click="OnNextFrame"
                                Style="{StaticResource GlyphButtonStyle}"
                                ToolTipService.ToolTip="다음 프레임 (→)">
                            <FontIcon Glyph="&#xE76C;" FontSize="13" />
                        </Button>
                        <Button x:Name="NextKeyframeButton" Click="OnNextKeyframe"
                                Style="{StaticResource GlyphButtonStyle}"
                                ToolTipService.ToolTip="다음 키프레임 (Ctrl+→)">
                            <FontIcon Glyph="&#xE893;" FontSize="13" />
                        </Button>
                    </StackPanel>

                    <!-- 볼륨 (우) -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                VerticalAlignment="Center" Spacing="2" Margin="0,0,2,0">
                        <Button x:Name="MuteButton" Click="OnMuteToggle"
                                Style="{StaticResource GlyphButtonStyle}"
                                Padding="4" ToolTipService.ToolTip="음소거 토글">
                            <FontIcon x:Name="VolumeIcon" Glyph="&#xE767;" FontSize="14" />
                        </Button>
                        <Slider x:Name="VolumeSlider"
                                Width="72" Minimum="0" Maximum="100" Value="100"
                                VerticalAlignment="Center"
                                ToolTipService.ToolTip="음량"
                                ValueChanged="OnVolumeChanged" />
                    </StackPanel>
                </Grid>

                <!-- ── Row 1: 통합 탐색 + 구간 선택 바 ──────────────── -->
                <ctl:TimelineRangeBar Grid.Row="1" x:Name="RangeBar"
                                      Margin="10,6" />

                <!-- ── Row 2: 하단 정보 바 ──────────────────────────── -->
                <Grid Grid.Row="2"
                      ColumnDefinitions="*,Auto,Auto"
                      ColumnSpacing="6" Padding="8,0"
                      Background="{StaticResource BcRailBrush}">

                    <!-- 타임코드 칩 -->
                    <Border Grid.Column="1"
                            Background="{StaticResource BcCardBrush}"
                            BorderBrush="{StaticResource BcDividerBrush}"
                            BorderThickness="1" CornerRadius="4"
                            Padding="8,3" VerticalAlignment="Center">
                        <TextBlock x:Name="PositionText2"
                                   Text="00:00:00.00 / 00:00:00.00"
                                   FontSize="11.5"
                                   Foreground="{StaticResource BcTextBrush}" />
                    </Border>

                    <!-- 범위 반복 재생 토글 -->
                    <ToggleButton Grid.Column="2" x:Name="LoopButton"
                                  Background="Transparent"
                                  BorderBrush="{StaticResource BcDividerBrush}"
                                  BorderThickness="1"
                                  Padding="6,2" MinWidth="34" MinHeight="24"
                                  CornerRadius="4"
                                  VerticalAlignment="Center"
                                  Checked="OnLoopChanged"
                                  Unchecked="OnLoopChanged"
                                  ToolTipService.ToolTip="범위 반복 재생">
                        <TextBlock x:Name="LoopLabel" Text="[&#x25B6;]" FontSize="11" />
                    </ToggleButton>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</UserControl>
