<?xml version="1.0" encoding="utf-8"?>
<local:WindowBase
    x:Class="VCut.App.OutputSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VCut.App"
    xmlns:vm="using:VCut.App.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" RowDefinitions="44,*,52" Background="{StaticResource BcAppBrush}">

        <!-- ════════ 헤더 바 ════════ -->
        <Grid Grid.Row="0" Background="{StaticResource BcRailBrush}" Padding="16,0">
            <TextBlock x:Name="HeaderText" Text="출력 설정" FontSize="14" FontWeight="SemiBold"
                       Foreground="{StaticResource BcTextBrush}" VerticalAlignment="Center"/>
        </Grid>

        <!-- ════════ 콘텐츠 ════════ -->
        <ScrollViewer Grid.Row="1" Padding="16">
            <StackPanel Spacing="14">

                <!-- 출력 방식 -->
                <StackPanel Spacing="6">
                    <TextBlock x:Name="TxtModeHeader" Text="출력 방식" FontWeight="SemiBold"
                               Foreground="{StaticResource BcTextBrush}"/>
                    <ToggleSwitch x:Name="TglFastMode"
                                  IsOn="{x:Bind VM.IsFastMode, Mode=TwoWay}"
                                  OnContent="고속 모드 (화질 저하 없는 빠른 작업)"
                                  OffContent="변환 모드 (재인코딩)"/>
                </StackPanel>

                <!-- 변환 모드 상세 (고속 모드일 때 숨김) -->
                <StackPanel Spacing="8" Visibility="{x:Bind VM.ConvertOptionsVisibility, Mode=OneWay}">
                    <ComboBox x:Name="CboFormat" Header="파일 형식"
                              SelectedIndex="{x:Bind VM.ContainerIndex, Mode=TwoWay}"
                              HorizontalAlignment="Stretch">
                        <ComboBoxItem Content="MP4"/>
                        <ComboBoxItem Content="MKV"/>
                        <ComboBoxItem Content="WebM (VP9)"/>
                        <ComboBoxItem Content="AVI"/>
                    </ComboBox>
                    <Slider x:Name="SldQuality" Header="품질 (낮을수록 용량↓)"
                            Minimum="10" Maximum="100"
                            Value="{x:Bind VM.Quality, Mode=TwoWay}"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBlock x:Name="TxtSpeedLabel" Grid.Column="0" Text="재생 속도"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource BcTextBrush}"
                                   ToolTipService.ToolTip="1.0=원본, 4.01↑ 오디오 자동 제거, 휠/↑↓로 조절"/>
                        <TextBox x:Name="SldSpeed" Grid.Column="1"
                                 Width="90" TextAlignment="Right" InputScope="Number"
                                 Text="{x:Bind local:SpeedFormat.Text(VM.SpeedFactor), Mode=OneWay}"
                                 LostFocus="OnMasterSpeedLostFocus" PreviewKeyDown="OnMasterSpeedKeyDown"
                                 PointerWheelChanged="OnMasterSpeedWheel"/>
                    </Grid>
                </StackPanel>

                <!-- 저장 폴더 -->
                <StackPanel Spacing="6">
                    <TextBlock x:Name="TxtFolderHeader" Text="저장 폴더" FontWeight="SemiBold"
                               Foreground="{StaticResource BcTextBrush}"/>
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                        <TextBox Grid.Column="0" x:Name="FolderBox"
                                 PlaceholderText="원본 파일과 같은 위치"/>
                        <Button Grid.Column="1" x:Name="BtnBrowseFolder"
                                Content="찾아보기…" Click="OnBrowseFolder"/>
                    </Grid>
                </StackPanel>

                <!-- 포함할 항목 -->
                <StackPanel Spacing="6">
                    <TextBlock x:Name="TxtItemsHeader" Text="포함할 항목" FontWeight="SemiBold"
                               Foreground="{StaticResource BcTextBrush}"/>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <RadioButton x:Name="RbPickInclude" Content="포함" GroupName="pickmode" IsChecked="True"/>
                        <RadioButton x:Name="RbPickRemove" Content="제거" GroupName="pickmode"
                                     IsChecked="{x:Bind VM.RemoveSelectedEnabled, Mode=TwoWay}"/>
                    </StackPanel>
                    <ItemsControl ItemsSource="{x:Bind VM.Segments}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ClipSegment">
                                <Grid Margin="{x:Bind CardIndent, Mode=OneWay}"
                                      ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                    <CheckBox Grid.Column="0"
                                              IsChecked="{x:Bind IsPicked, Mode=TwoWay}"
                                              Content="{x:Bind PickLabel, Mode=OneWay}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4"
                                                VerticalAlignment="Center">
                                        <Button Height="32" MinWidth="60" Padding="0" FontSize="12"
                                                HorizontalContentAlignment="Center"
                                                Visibility="{x:Bind SpeedIsDefault, Mode=OneWay}"
                                                Click="OnEnableRowSpeed"
                                                ToolTipService.ToolTip="재생 속도 개별 설정"
                                                Content="배속"/>
                                        <Button Style="{StaticResource GlyphButtonStyle}"
                                                Height="32" Width="32" Padding="0"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Visibility="{x:Bind SpeedIsCustom, Mode=OneWay}"
                                                Click="OnResetRowSpeed"
                                                ToolTipService.ToolTip="공통 배속으로 초기화">
                                            <FontIcon Glyph="&#xE777;" FontSize="12"/>
                                        </Button>
                                        <TextBox Height="32" Width="60"
                                                 TextAlignment="Right" InputScope="Number"
                                                 Visibility="{x:Bind SpeedIsCustom, Mode=OneWay}"
                                                 ToolTipService.ToolTip="이 구간의 배속 (휠/↑↓로 조절)"
                                                 Text="{x:Bind local:SpeedFormat.Text(Speed), Mode=OneWay}"
                                                 LostFocus="OnRowSpeedLostFocus" PreviewKeyDown="OnRowSpeedKeyDown"
                                                 PointerWheelChanged="OnRowSpeedWheel"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- 옵션 -->
                <StackPanel Spacing="6">
                    <TextBlock x:Name="TxtOptionsHeader" Text="옵션" FontWeight="SemiBold"
                               Foreground="{StaticResource BcTextBrush}"/>
                    <CheckBox x:Name="CbMerge" Content="하나의 영상으로 합치기"
                              IsChecked="{x:Bind VM.MergeEnabled, Mode=TwoWay}"
                              IsEnabled="{x:Bind VM.CanEditMerge, Mode=OneWay}"/>
                    <CheckBox x:Name="CbSavePlayback"
                              Content="재생 시간 정보를 텍스트(txt) 파일로 저장하기"
                              IsChecked="{x:Bind VM.WritePlaybackInfo, Mode=TwoWay}"/>
                    <CheckBox x:Name="CbExtractAudio" Content="오디오 트랙 추출하기 (.mp3)"
                              IsChecked="{x:Bind VM.ExtractAudioOnly, Mode=TwoWay}"/>
                    <CheckBox x:Name="CbRemoveAudio" Content="오디오 트랙 제거하기"
                              IsChecked="{x:Bind VM.RemoveAudio, Mode=TwoWay}"/>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- ════════ 하단 버튼 바 ════════ -->
        <Grid Grid.Row="2" Background="{StaticResource BcRailBrush}" Padding="12,0">
            <Border VerticalAlignment="Top" Height="1" Background="{StaticResource BcDividerBrush}"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                        Spacing="8" VerticalAlignment="Center">
                <Button x:Name="BtnCancel" Content="취소" Click="OnCancel"/>
                <Button x:Name="BtnStart"  Content="시작"  Click="OnStart"
                        Style="{StaticResource AccentButtonStyle}"/>
            </StackPanel>
        </Grid>

    </Grid>
</local:WindowBase>
