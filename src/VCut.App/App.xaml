<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="VCut.App.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:VCut.App.Converters"
    RequestedTheme="Dark">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
                <ResourceDictionary Source="ms-appx:///Themes/Theme.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:InverseBooleanConverter x:Key="NotConverter" />
            <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/JetBrainsMono-Regular.ttf#JetBrains Mono</FontFamily>
        </ResourceDictionary>
    </Application.Resources>
</Application>
