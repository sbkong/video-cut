<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════ JetBrains Dark (New UI) 팔레트 ════════ -->
    <Color x:Key="BcApp">#FF1E1F22</Color>
    <Color x:Key="BcRail">#FF1A1B1E</Color>
    <Color x:Key="BcPanel">#FF2B2D30</Color>
    <Color x:Key="BcPanelDark">#FF1E1F22</Color>
    <Color x:Key="BcCard">#FF313335</Color>
    <Color x:Key="BcCardHover">#FFF9F9FA</Color>
    <Color x:Key="BcAccent">#FF3574F0</Color>
    <Color x:Key="BcAccentHover">#FF4A83F0</Color>
    <Color x:Key="BcText">#FFBCBEC4</Color>
    <Color x:Key="BcTextSecondary">#FF7A7E85</Color>
    <Color x:Key="BcDivider">#FF393B40</Color>
    <Color x:Key="BcSliderTrack">#FF3A3D42</Color>

    <SolidColorBrush x:Key="BcAppBrush" Color="{StaticResource BcApp}" />
    <SolidColorBrush x:Key="BcRailBrush" Color="{StaticResource BcRail}" />
    <SolidColorBrush x:Key="BcPanelBrush" Color="{StaticResource BcPanel}" />
    <SolidColorBrush x:Key="BcPanelDarkBrush" Color="{StaticResource BcPanelDark}" />
    <SolidColorBrush x:Key="BcCardBrush" Color="{StaticResource BcCard}" />
    <SolidColorBrush x:Key="BcCardHoverBrush" Color="{StaticResource BcCardHover}" />
    <SolidColorBrush x:Key="BcAccentBrush" Color="{StaticResource BcAccent}" />
    <SolidColorBrush x:Key="BcAccentHoverBrush" Color="{StaticResource BcAccentHover}" />
    <SolidColorBrush x:Key="BcTextBrush" Color="{StaticResource BcText}" />
    <SolidColorBrush x:Key="BcTextSecondaryBrush" Color="{StaticResource BcTextSecondary}" />
    <SolidColorBrush x:Key="BcDividerBrush" Color="{StaticResource BcDivider}" />
    <SolidColorBrush x:Key="BcSliderTrackBrush" Color="{StaticResource BcSliderTrack}" />

    <!-- ════════ 시맨틱(의미) 컬러 ════════
         런타임에 ThemeService가 라이트/다크로 교체. 초기값은 다크 팔레트.
         Danger=파괴/오류, Warning=주의/재생헤드, Success=완료 -->
    <Color x:Key="BcDanger">#FFC24545</Color>
    <Color x:Key="BcDangerHover">#FFD35C5C</Color>
    <Color x:Key="BcDangerPressed">#FFA33A3A</Color>
    <Color x:Key="BcDangerText">#FFE5534B</Color>
    <Color x:Key="BcWarning">#FFF5A623</Color>
    <Color x:Key="BcWarningText">#FFF5A623</Color>
    <Color x:Key="BcSuccess">#FF499C54</Color>
    <Color x:Key="BcSuccessText">#FF5FAD65</Color>

    <SolidColorBrush x:Key="BcDangerBrush" Color="{StaticResource BcDanger}" />
    <SolidColorBrush x:Key="BcDangerHoverBrush" Color="{StaticResource BcDangerHover}" />
    <SolidColorBrush x:Key="BcDangerPressedBrush" Color="{StaticResource BcDangerPressed}" />
    <SolidColorBrush x:Key="BcDangerTextBrush" Color="{StaticResource BcDangerText}" />
    <SolidColorBrush x:Key="BcWarningBrush" Color="{StaticResource BcWarning}" />
    <SolidColorBrush x:Key="BcWarningTextBrush" Color="{StaticResource BcWarningText}" />
    <SolidColorBrush x:Key="BcSuccessBrush" Color="{StaticResource BcSuccess}" />
    <SolidColorBrush x:Key="BcSuccessTextBrush" Color="{StaticResource BcSuccessText}" />

    <!-- ════════ 타입 스케일(폰트 크기 토큰) ════════
         테마 무관 상수. 인라인 FontSize 대신 이 토큰을 참조해 통일한다. -->
    <x:Double x:Key="FsMicro">10</x:Double>
    <x:Double x:Key="FsCaptionSmall">11</x:Double>
    <x:Double x:Key="FsCaption">12</x:Double>
    <x:Double x:Key="FsBody">13</x:Double>
    <x:Double x:Key="FsBodyLarge">14</x:Double>
    <x:Double x:Key="FsSubtitle">15</x:Double>
    <x:Double x:Key="FsTitle">16</x:Double>

    <!-- ════════ 전역 폰트 통일 ════════
         순정 TextBlock은 앱 폰트(ContentControlThemeFontFamily)를 기본으로 따르지 않고,
         루트에 건 FontFamily 상속도 TextBlock까진 닿지 않는다. 그래서 암시적 스타일로 모든
         TextBlock이 앱 폰트를 쓰도록 통일한다(개별 FontSize/FontWeight 등 지역 설정은 그대로 우선). -->
    <Style TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
    </Style>

    <!-- 시스템 액센트(AccentButton 등)를 통일 -->
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource BcAccent}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource BcAccentHover}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource BcAccent}" />

    <!-- ════════ 좌측 레일 아이콘 버튼 ════════ -->
    <Style x:Key="RailButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BcTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="45" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="20" />
    </Style>

    <!-- 활성 레일 버튼(좌측 파란 막대 강조) -->
    <Style x:Key="RailButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource RailButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource BcTextBrush}" />
        <Setter Property="Background" Value="{StaticResource BcPanelBrush}" />
    </Style>

    <!-- ════════ 주요 버튼(홈 화면 "시작"처럼 화면당 하나뿐인 큰 CTA) ════════ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Height" Value="40" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- ════════ 대화상자 하단 버튼(저장/확인 — "영상 추가" 버튼과 같은 크기의 표준 버튼) ════════ -->
    <Style x:Key="DialogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- ════════ 대화상자 하단 버튼(취소/초기화/재시작 등) — DialogPrimaryButtonStyle과 같은 크기, 중립 색상 ════════ -->
    <Style x:Key="DialogSecondaryButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="88" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{StaticResource BcPanelBrush}" />
        <Setter Property="Foreground" Value="{StaticResource BcTextBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BcDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <!-- ════════ ContentDialog 기본 버튼도 같은 스타일로 통일 ════════ -->
    <Style TargetType="ContentDialog">
        <Setter Property="PrimaryButtonStyle" Value="{StaticResource DialogPrimaryButtonStyle}" />
        <Setter Property="SecondaryButtonStyle" Value="{StaticResource DialogSecondaryButtonStyle}" />
        <Setter Property="CloseButtonStyle" Value="{StaticResource DialogSecondaryButtonStyle}" />
    </Style>

    <!-- ════════ 취소 버튼(빨간 버튼, 처리 중 시작 버튼 자리에 표시) ════════ -->
    <Style x:Key="CancelButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Height" Value="40" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="{StaticResource BcDangerBrush}" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Padding" Value="12,4,12,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Background" Value="{StaticResource BcDangerHoverBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Background" Value="{StaticResource BcDangerPressedBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Opacity" Value="0.5" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTransitions="{TemplateBinding ContentTransitions}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Padding="{TemplateBinding Padding}"
                                          AutomationProperties.AccessibilityView="Raw" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ 미리보기 헤더/전송용 아이콘 버튼 ════════ -->
    <Style x:Key="GlyphButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BcTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="7" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- ════════ 구간 카드 ════════ -->
    <Style x:Key="SegmentCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BcCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BcDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="8" />
    </Style>

</ResourceDictionary>
