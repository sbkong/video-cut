<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════ JetBrains Dark (New UI) 팔레트 ════════ -->
    <Color x:Key="BcApp">#FF1E1F22</Color>
    <Color x:Key="BcRail">#FF1A1B1E</Color>
    <Color x:Key="BcPanel">#FF2B2D30</Color>
    <Color x:Key="BcPanelDark">#FF1E1F22</Color>
    <Color x:Key="BcCard">#FF313335</Color>
    <Color x:Key="BcCardHover">#FFF9F9FA</Color>
    <Color x:Key="BcAccent">#FF3574F0</Color>
    <Color x:Key="BcAccentHover">#FF4A83F0</Color>
    <Color x:Key="BcText">#FFBCBEC4</Color>
    <Color x:Key="BcTextSecondary">#FF7A7E85</Color>
    <Color x:Key="BcDivider">#FF393B40</Color>
    <Color x:Key="BcSliderTrack">#FF3A3D42</Color>

    <SolidColorBrush x:Key="BcAppBrush" Color="{StaticResource BcApp}" />
    <SolidColorBrush x:Key="BcRailBrush" Color="{StaticResource BcRail}" />
    <SolidColorBrush x:Key="BcPanelBrush" Color="{StaticResource BcPanel}" />
    <SolidColorBrush x:Key="BcPanelDarkBrush" Color="{StaticResource BcPanelDark}" />
    <SolidColorBrush x:Key="BcCardBrush" Color="{StaticResource BcCard}" />
    <SolidColorBrush x:Key="BcCardHoverBrush" Color="{StaticResource BcCardHover}" />
    <SolidColorBrush x:Key="BcAccentBrush" Color="{StaticResource BcAccent}" />
    <SolidColorBrush x:Key="BcAccentHoverBrush" Color="{StaticResource BcAccentHover}" />
    <SolidColorBrush x:Key="BcTextBrush" Color="{StaticResource BcText}" />
    <SolidColorBrush x:Key="BcTextSecondaryBrush" Color="{StaticResource BcTextSecondary}" />
    <SolidColorBrush x:Key="BcDividerBrush" Color="{StaticResource BcDivider}" />

    <!-- 시스템 액센트(AccentButton 등)를 통일 -->
    <SolidColorBrush x:Key="AccentFillColorDefaultBrush" Color="{StaticResource BcAccent}" />
    <SolidColorBrush x:Key="AccentFillColorSecondaryBrush" Color="{StaticResource BcAccentHover}" />
    <SolidColorBrush x:Key="AccentFillColorTertiaryBrush" Color="{StaticResource BcAccent}" />

    <!-- ════════ 좌측 레일 아이콘 버튼 ════════ -->
    <Style x:Key="RailButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BcTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="56" />
        <Setter Property="Height" Value="52" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontSize" Value="20" />
    </Style>

    <!-- 활성 레일 버튼(좌측 파란 막대 강조) -->
    <Style x:Key="RailButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource RailButtonStyle}">
        <Setter Property="Foreground" Value="{StaticResource BcTextBrush}" />
        <Setter Property="Background" Value="{StaticResource BcPanelBrush}" />
    </Style>

    <!-- ════════ 시작 버튼(큰 파란 버튼) ════════ -->
    <Style x:Key="StartButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Height" Value="40" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="4" />
    </Style>

    <!-- ════════ 취소 버튼(빨간 버튼, 처리 중 시작 버튼 자리에 표시) ════════ -->
    <Style x:Key="CancelButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="120" />
        <Setter Property="Height" Value="40" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Background" Value="#FFC24545" />
        <Setter Property="Foreground" Value="White" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <!-- ════════ 미리보기 헤더/전송용 아이콘 버튼 ════════ -->
    <Style x:Key="GlyphButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource BcTextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="7" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="FontSize" Value="15" />
    </Style>

    <!-- ════════ 구간 카드 ════════ -->
    <Style x:Key="SegmentCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BcCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BcDividerBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="5" />
        <Setter Property="Padding" Value="8" />
    </Style>

</ResourceDictionary>
