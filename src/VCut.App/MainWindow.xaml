<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="VCut.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ctl="using:VCut.Controls"
    xmlns:vm="using:VCut.App.ViewModels"
    xmlns:conv="using:VCut.App.Converters"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid x:Name="Root" RowDefinitions="44,*,26" Background="{StaticResource BcAppBrush}" KeyboardAcceleratorPlacementMode="Hidden">

        <!-- ════════ 메뉴 바 ════════ -->
        <Grid Grid.Row="0" Background="{StaticResource BcRailBrush}" ColumnDefinitions="Auto,Auto,Auto,*">

            <!-- 앱 아이콘 -->
            <Border Grid.Column="0" Width="26" Height="26" Background="{StaticResource BcAccentBrush}" CornerRadius="7"
                    VerticalAlignment="Center" Margin="12,0,0,0">
                <FontIcon Glyph="&#xE8C6;" FontSize="{StaticResource FsBody}" Foreground="White" />
            </Border>

            <!-- ≡ 메뉴 버튼 -->
            <Button Grid.Column="1" Height="44" Padding="12,0" VerticalAlignment="Stretch" Margin="8,0,0,0"
                    Background="Transparent" BorderThickness="0">
                <FontIcon Glyph="&#xE700;" FontSize="{StaticResource FsSubtitle}" Foreground="{StaticResource BcTextBrush}" />
                <Button.Flyout>
                    <MenuFlyout Placement="Bottom">
                        <MenuFlyoutItem x:Name="MenuSettings" Text="환경 설정" Click="OnOpenSettings">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE713;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="MenuAbout" Text="v-cut 정보" Click="OnRailInfo">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE946;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="MenuRestart" Text="재시작" Click="OnRestart">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE72C;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuExit" Text="종료" Click="OnExit">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7E8;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!-- 프로젝트 드롭다운 -->
            <Button Grid.Column="2" Height="44" Padding="12,0" VerticalAlignment="Stretch" Margin="2,0"
                    Background="Transparent" BorderThickness="0">
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="{x:Bind VM.CurrentProjectName, Mode=OneWay}"
                               VerticalAlignment="Center" FontSize="{StaticResource FsBody}"
                               Foreground="{StaticResource BcTextBrush}" />
                    <FontIcon Glyph="&#xE70D;" FontSize="9" VerticalAlignment="Center"
                              Foreground="{StaticResource BcTextSecondaryBrush}" Margin="0,2,0,0" />
                </StackPanel>
                <Button.Flyout>
                    <MenuFlyout x:Name="ProjectFlyout" Placement="Bottom" Opening="OnProjectFlyoutOpening">
                        <MenuFlyoutItem x:Name="MenuNewProject" Text="새 프로젝트" Command="{x:Bind VM.NewProjectCommand}">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE710;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuOpenProject" Text="열기..." Command="{x:Bind VM.OpenProjectCommand}">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE8DA;" /></MenuFlyoutItem.Icon>
                        </MenuFlyoutItem>
                        <MenuFlyoutSeparator />
                        <MenuFlyoutItem x:Name="MenuSave" Text="저장" Command="{x:Bind VM.SaveProjectCommand}">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74E;" /></MenuFlyoutItem.Icon>
                            <MenuFlyoutItem.KeyboardAcceleratorTextOverride>Ctrl+S</MenuFlyoutItem.KeyboardAcceleratorTextOverride>
                        </MenuFlyoutItem>
                        <MenuFlyoutItem x:Name="MenuSaveAs" Text="다른 이름으로 저장" Command="{x:Bind VM.SaveProjectAsCommand}">
                            <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE792;" /></MenuFlyoutItem.Icon>
                            <MenuFlyoutItem.KeyboardAcceleratorTextOverride>Ctrl+Shift+S</MenuFlyoutItem.KeyboardAcceleratorTextOverride>
                        </MenuFlyoutItem>
                    </MenuFlyout>
                </Button.Flyout>
            </Button>

            <!-- 빈 드래그 영역 -->
            <Grid Grid.Column="3" />
        </Grid>

        <!-- ════════ 본문: 레일 + 구간목록 + 미리보기 ════════ -->
        <Grid Grid.Row="1" ColumnDefinitions="56,*">

            <!-- 좌측 아이콘 레일 -->
            <Grid Grid.Column="0" Background="{StaticResource BcRailBrush}" RowDefinitions="Auto,*,Auto">
                <StackPanel Grid.Row="0">
                    <Button x:Name="RailHome" Style="{StaticResource RailButtonStyle}" Click="OnRailHome" ToolTipService.ToolTip="홈"><FontIcon Glyph="&#xE80F;" /></Button>
                    <Button x:Name="RailTrim" Style="{StaticResource RailButtonStyle}" Click="OnRailTrim" ToolTipService.ToolTip="자르기"><FontIcon Glyph="&#xE8C6;" /></Button>
                    <Button x:Name="RailSplit" Style="{StaticResource RailButtonStyle}" Click="OnRailSplit" ToolTipService.ToolTip="나누기"><FontIcon Glyph="&#xE8CA;" /></Button>
                </StackPanel>
                <StackPanel Grid.Row="2" />
            </Grid>

            <!-- 편집 화면(구간목록 + 미리보기) -->
            <Grid x:Name="EditGrid" Grid.Column="1" ColumnDefinitions="300,*">

                <!-- 구간 목록 패널 -->
                <Grid Grid.Column="0" Background="{StaticResource BcPanelBrush}" RowDefinitions="Auto,*,Auto" Padding="12"
                      AllowDrop="True" DragOver="OnSegmentListDragOver" Drop="OnSegmentListDrop">
                    <Grid Grid.Row="0" Margin="0,0,0,8">
                        <TextBlock x:Name="ListTitle" Text="자르기 구간 목록" FontWeight="SemiBold" Foreground="{StaticResource BcTextBrush}" />
                        <TextBlock x:Name="TotalDurText" Foreground="{StaticResource BcTextSecondaryBrush}" FontSize="{StaticResource FsCaption}" HorizontalAlignment="Right">
                            <Run Text="전체 길이 " /><Run Text="{x:Bind VM.TotalDurationText, Mode=OneWay}" />
                        </TextBlock>
                    </Grid>

                    <!-- 빈 상태(+) / 목록 -->
                    <Grid Grid.Row="1">
                        <Border Visibility="{x:Bind VM.HasNoSegments, Mode=OneWay}"
                                BorderBrush="{StaticResource BcDividerBrush}" BorderThickness="2" CornerRadius="8"
                                Background="{StaticResource BcPanelDarkBrush}">
                            <Button Click="OnOpenClick" Background="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <FontIcon Glyph="&#xE710;" FontSize="36" Foreground="{StaticResource BcTextSecondaryBrush}" />
                                    <TextBlock x:Name="EmptyAddLabel" Text="영상 추가" Foreground="{StaticResource BcTextSecondaryBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </Border>

                        <ListView x:Name="SegmentList" ItemsSource="{x:Bind VM.Segments}"
                                  Visibility="{x:Bind VM.HasSegments, Mode=OneWay}"
                                  SelectionMode="Extended" Background="Transparent"
                                  Padding="0,0,14,0"
                                  CanReorderItems="True" CanDragItems="True" AllowDrop="True"
                                  SelectionChanged="OnSegmentListSelectionChanged"
                                  DragItemsStarting="OnDragItemsStarting"
                                  DragItemsCompleted="OnDragItemsCompleted"
                                  RightTapped="OnSegmentListRightTapped">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:ClipSegment">
                                    <Grid Margin="{x:Bind CardIndent, Mode=OneWay}">
                                        <Border Style="{StaticResource SegmentCardStyle}" Opacity="{x:Bind CardOpacity, Mode=OneWay}"
                                                PointerEntered="OnCardPointerEntered"
                                                PointerExited="OnCardPointerExited">
                                            <Border.BackgroundTransition>
                                                <BrushTransition Duration="0:0:0.12" />
                                            </Border.BackgroundTransition>
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="10">
                                                <!-- 썸네일 + 길이 배지 -->
                                                <Border Grid.Column="0" Width="56" Height="42" CornerRadius="4"
                                                        Background="{StaticResource BcPanelDarkBrush}">
                                                    <Grid>
                                                        <Image Source="{x:Bind ThumbnailSource, Mode=OneWay}"
                                                               Stretch="UniformToFill" />
                                                        <!-- 썸네일 로딩 전 또는 파일 없을 때 번호 표시 -->
                                                        <TextBlock Text="{x:Bind DisplayIndex, Mode=OneWay}" FontWeight="Bold" FontSize="{StaticResource FsTitle}"
                                                                   Foreground="{StaticResource BcTextBrush}"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   Visibility="{x:Bind ThumbnailFallbackVisibility, Mode=OneWay}" />
                                                        <Border Background="#AA000000" CornerRadius="0,0,4,4" VerticalAlignment="Bottom" Padding="2,0">
                                                            <TextBlock Text="{x:Bind DurationText}" FontSize="9" Foreground="White" HorizontalAlignment="Center" />
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                    <TextBlock Text="{x:Bind FileName}" Foreground="{StaticResource BcTextBrush}"
                                                               FontSize="{StaticResource FsBody}" TextTrimming="CharacterEllipsis" />
                                                    <TextBlock Text="{x:Bind RangeText, Mode=OneWay}" Foreground="{StaticResource BcTextSecondaryBrush}"
                                                               FontSize="11.5" TextTrimming="CharacterEllipsis" Visibility="{x:Bind ExistsVisibility}" />
                                                    <TextBlock Text="{x:Bind MissingText}" Foreground="{StaticResource BcTextSecondaryBrush}"
                                                               FontSize="11.5" Visibility="{x:Bind MissingVisibility}" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                        <!-- 선택 표시 링 -->
                                        <Border BorderBrush="{ThemeResource SystemAccentColorLight2}"
                                                BorderThickness="2"
                                                CornerRadius="5"
                                                IsHitTestVisible="False"
                                                Visibility="{x:Bind SelectedVisibility, Mode=OneWay}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>

                    <!-- 목록 하단 도구 -->
                    <Grid Grid.Row="2" Margin="0,8,0,0" ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                        <Button x:Name="BtnDeleteSeg" Grid.Column="0" Style="{StaticResource GlyphButtonStyle}" Command="{x:Bind VM.RemoveSelectedClipCommand}" ToolTipService.ToolTip="구간 삭제"><FontIcon Glyph="&#xE74D;" FontSize="{StaticResource FsBody}" /></Button>
                        <Button x:Name="BtnMoveUp2" Grid.Column="1" Style="{StaticResource GlyphButtonStyle}" Command="{x:Bind VM.MoveClipUpCommand}" ToolTipService.ToolTip="위로"><FontIcon Glyph="&#xE70E;" FontSize="{StaticResource FsBody}" /></Button>
                        <Button x:Name="BtnMoveDown2" Grid.Column="2" Style="{StaticResource GlyphButtonStyle}" Command="{x:Bind VM.MoveClipDownCommand}" ToolTipService.ToolTip="아래로"><FontIcon Glyph="&#xE70D;" FontSize="{StaticResource FsBody}" /></Button>
                        <Button x:Name="BtnAddVideo2" Grid.Column="4" Content="영상 추가" Click="OnOpenClick" />
                    </Grid>
                </Grid>

                <!-- 미리보기 패널 -->
                <Grid Grid.Column="1" Background="{StaticResource BcPanelDarkBrush}" RowDefinitions="Auto,*,Auto,Auto" Padding="12">
                    <!-- 헤더 -->
                    <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,8">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="4">
                            <Button x:Name="BtnResetTransform" Style="{StaticResource GlyphButtonStyle}" Command="{x:Bind VM.ApplyTransformCommand}" CommandParameter="none"  ToolTipService.ToolTip="초기화 (회전/반전 없음)"><FontIcon Glyph="&#xE777;" FontSize="{StaticResource FsBodyLarge}" /></Button>
                            <Button x:Name="BtnRotate90" Style="{StaticResource GlyphButtonStyle}" Command="{x:Bind VM.ApplyTransformCommand}" CommandParameter="90"    ToolTipService.ToolTip="90° 회전"><FontIcon Glyph="&#xE7AD;" FontSize="{StaticResource FsBodyLarge}" /></Button>
                            <Button x:Name="BtnFlipH" Style="{StaticResource GlyphButtonStyle}" Command="{x:Bind VM.ApplyTransformCommand}" CommandParameter="hflip" ToolTipService.ToolTip="좌우 반전">
                                <FontIcon FontFamily="Segoe UI Symbol" Glyph="&#x2194;" FontSize="{StaticResource FsTitle}" Width="16" Height="16" />
                            </Button>
                            <Button x:Name="BtnFlipV" Style="{StaticResource GlyphButtonStyle}" Command="{x:Bind VM.ApplyTransformCommand}" CommandParameter="vflip" ToolTipService.ToolTip="상하 반전">
                                <FontIcon FontFamily="Segoe UI Symbol" Glyph="&#x2195;" FontSize="{StaticResource FsTitle}" Width="16" Height="16" />
                            </Button>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{x:Bind VM.MediaSummary, Mode=OneWay}" Foreground="{StaticResource BcTextSecondaryBrush}"
                                   FontSize="{StaticResource FsCaption}" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                        <Button x:Name="BtnCaptureFrame" Grid.Column="2" Style="{StaticResource GlyphButtonStyle}" Click="OnCaptureClick" ToolTipService.ToolTip="화면 캡처(PNG)"><FontIcon Glyph="&#xE722;" FontSize="{StaticResource FsBodyLarge}" /></Button>
                    </Grid>

                    <!-- 미리보기 (통합 탐색+구간 바 내장) -->
                    <ctl:VideoPreview x:Name="Preview" Grid.Row="1"
                                      Duration="{x:Bind VM.MediaDuration, Mode=OneWay}"
                                      TrimStart="{x:Bind VM.TrimStart, Mode=TwoWay}"
                                      TrimEnd="{x:Bind VM.TrimEnd, Mode=TwoWay}"
                                      VideoRotation="{x:Bind VM.VideoRotation, Mode=OneWay}"
                                      FlipH="{x:Bind VM.FlipH, Mode=OneWay}"
                                      FlipV="{x:Bind VM.FlipV, Mode=OneWay}"
                                      Speed="{x:Bind VM.SpeedFactor, Mode=TwoWay}" />

                    <!-- 구간 미세조정 -->
                    <StackPanel x:Name="TrimControlsArea" Grid.Row="2" Margin="0,8,0,0" Spacing="4"
                                SizeChanged="OnTrimControlsAreaSizeChanged">

                        <!-- 컨트롤 행 -->
                        <StackPanel x:Name="TrimControlsRow" Orientation="Horizontal" HorizontalAlignment="Center"
                                    Spacing="6" VerticalAlignment="Center">

                            <!-- 시작 설정 -->
                            <Button x:Name="BtnSetStart" MinWidth="0" MinHeight="0" Height="28" Padding="7,0" Click="OnSetStartToCurrent"
                                    ToolTipService.ToolTip="현재 위치를 시작 구간으로 ([)">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE892;" FontSize="{StaticResource FsCaptionSmall}" />
                                    <TextBlock x:Name="LblSetStart" Text="시작" FontSize="{StaticResource FsCaptionSmall}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                            <ctl:TimeCodeBox Time="{x:Bind VM.TrimStart, Mode=TwoWay}"
                                             FrameRate="{x:Bind VM.FrameRate, Mode=OneWay}" />
                            <ctl:TimeCodeBox Time="{x:Bind VM.TrimEnd, Mode=TwoWay}"
                                             FrameRate="{x:Bind VM.FrameRate, Mode=OneWay}" />
                            <!-- 끝 설정 -->
                            <Button x:Name="BtnSetEnd" MinWidth="0" MinHeight="0" Height="28" Padding="7,0" Click="OnSetEndToCurrent"
                                    ToolTipService.ToolTip="현재 위치를 끝 구간으로 (])">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <TextBlock x:Name="LblSetEnd" Text="끝" FontSize="{StaticResource FsCaptionSmall}" VerticalAlignment="Center" />
                                    <FontIcon Glyph="&#xE893;" FontSize="{StaticResource FsCaptionSmall}" />
                                </StackPanel>
                            </Button>

                            <!-- 구분선 -->
                            <Border Width="1" Height="18" Background="{StaticResource BcDividerBrush}"
                                    VerticalAlignment="Center" Margin="2,0" />

                            <!-- 구간 재생/정지 -->
                            <Button x:Name="BtnRangePlay" MinWidth="0" MinHeight="0" Height="28" Padding="8,0" Click="OnRangePlayPause"
                                    ToolTipService.ToolTip="구간 재생/일시정지">
                                <FontIcon x:Name="RangePlayIcon" Glyph="&#xE768;" FontSize="{StaticResource FsBody}" />
                            </Button>
                            <Button x:Name="BtnRangeStop" MinWidth="0" MinHeight="0" Height="28" Padding="8,0" Click="OnRangeStop"
                                    ToolTipService.ToolTip="구간 재생 중지">
                                <FontIcon Glyph="&#xE71A;" FontSize="{StaticResource FsBody}" />
                            </Button>

                            <!-- 구분선 -->
                            <Border x:Name="AddRangeDivider" Width="1" Height="18" Background="{StaticResource BcDividerBrush}"
                                    VerticalAlignment="Center" Margin="2,0" Visibility="Collapsed" />

                            <!-- 자르기 화면 전용: 현재 시작~끝을 같은 파일의 하위 구간으로 목록에 추가 -->
                            <Button x:Name="BtnAddRange" MinWidth="0" MinHeight="0" Height="28" Padding="8,0"
                                    Command="{x:Bind VM.AddCurrentRangeCommand}"
                                    ToolTipService.ToolTip="현재 시작~끝을 하위 구간으로 목록에 추가"
                                    Visibility="Collapsed">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <FontIcon Glyph="&#xE710;" FontSize="{StaticResource FsCaptionSmall}" />
                                    <TextBlock x:Name="LblAddRange" Text="구간 추가" FontSize="{StaticResource FsCaptionSmall}" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>

                        </StackPanel>


                    </StackPanel>

                    <!-- 옵션(화면별) + 시작/취소 (모든 화면 공용) -->
                    <Grid Grid.Row="3" Margin="0,8,0,0" ColumnDefinitions="*,Auto">
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <StackPanel x:Name="SplitOptions" Orientation="Horizontal" Spacing="8"
                                        VerticalAlignment="Center" Visibility="Collapsed">
                                <RadioButton x:Name="RbSplitCount" Content="개수" GroupName="sp" IsChecked="{x:Bind VM.SplitByCount, Mode=TwoWay}" MinWidth="0" />
                                <NumberBox Value="{x:Bind VM.SplitCount, Mode=TwoWay}" Minimum="2" Maximum="99" Width="80" SpinButtonPlacementMode="Compact" />
                                <RadioButton x:Name="RbSplitTime" Content="시간(초)" GroupName="sp" MinWidth="0" />
                                <NumberBox Value="{x:Bind VM.SplitSeconds, Mode=TwoWay}" Minimum="1" Width="80" SpinButtonPlacementMode="Compact" IsEnabled="{x:Bind VM.SplitByTime, Mode=OneWay}" />
                                <Button x:Name="BtnSplitRun" Content="나누기 실행" Command="{x:Bind VM.RunSplitCommand}" Padding="10,0" />
                            </StackPanel>
                        </StackPanel>
                        <Grid Grid.Column="1">
                            <Button x:Name="StartButton" Content="시작" Style="{StaticResource PrimaryButtonStyle}" Click="OnStartClick" />
                            <Button x:Name="CancelButton" Content="취소" Style="{StaticResource CancelButtonStyle}" Command="{x:Bind VM.CancelCommand}" Visibility="Collapsed" />
                        </Grid>
                    </Grid>
                </Grid>

                <!-- 구간목록 / 미리보기 경계선 -->
                <Border Grid.Column="1" HorizontalAlignment="Left" Width="1" Background="{StaticResource BcDividerBrush}" />
            </Grid>

            <!-- 홈 화면 오버레이(3 타일 + 최근 프로젝트) -->
            <Grid x:Name="HomeOverlay" Grid.Column="1" Background="{StaticResource BcPanelDarkBrush}" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="340" />
                    <RowDefinition Height="*" MinHeight="80" />
                </Grid.RowDefinitions>

                <!-- 브랜딩 + 타일: Row 0 중앙 -->
                <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="36">

                    <!-- 브랜딩 헤더 -->
                    <StackPanel HorizontalAlignment="Center" Spacing="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" VerticalAlignment="Center">
                            <Border Width="68" Height="68" Background="{StaticResource BcAccentBrush}" CornerRadius="18">
                                <FontIcon Glyph="&#xE8C6;" FontSize="36" Foreground="White" />
                            </Border>
                            <StackPanel VerticalAlignment="Center" Spacing="5">
                                <StackPanel Orientation="Horizontal" Spacing="0">
                                    <TextBlock Text="v" FontSize="50" FontWeight="Bold"
                                               Foreground="{StaticResource BcAccentBrush}" LineHeight="54" />
                                    <TextBlock Text="-cut" FontSize="50" FontWeight="Bold"
                                               Foreground="{StaticResource BcTextBrush}" LineHeight="54" />
                                </StackPanel>
                                <TextBlock x:Name="HomeTagline" Text="빠르고 간단한 영상 편집 도구"
                                           FontSize="{StaticResource FsBody}" CharacterSpacing="30"
                                           Foreground="{StaticResource BcTextSecondaryBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- 모드 타일 -->
                    <StackPanel Orientation="Horizontal" Spacing="16" HorizontalAlignment="Center">
                        <Button Click="OnTileTrim" Width="158" Height="158" Background="{StaticResource BcCardBrush}" CornerRadius="10">
                            <StackPanel Spacing="12"><FontIcon Glyph="&#xE8C6;" FontSize="40" Foreground="{StaticResource BcAccentBrush}" /><TextBlock x:Name="TileTrimText" Text="자르기" Foreground="{StaticResource BcTextBrush}" HorizontalAlignment="Center" FontSize="{StaticResource FsBodyLarge}" FontWeight="SemiBold" /></StackPanel>
                        </Button>
                        <Button Click="OnTileSplit" Width="158" Height="158" Background="{StaticResource BcCardBrush}" CornerRadius="10">
                            <StackPanel Spacing="12"><FontIcon Glyph="&#xE8CA;" FontSize="40" Foreground="{StaticResource BcAccentBrush}" /><TextBlock x:Name="TileSplitText" Text="나누기" Foreground="{StaticResource BcTextBrush}" HorizontalAlignment="Center" FontSize="{StaticResource FsBodyLarge}" FontWeight="SemiBold" /></StackPanel>
                        </Button>
                    </StackPanel>
                </StackPanel>

                <!-- 최근 프로젝트: 창 높이에 비례해 자동 조절 -->
                <Grid Grid.Row="1" HorizontalAlignment="Center" Width="506"
                      Visibility="{x:Bind VM.HasRecentProjects, Mode=OneWay}"
                      Margin="0,0,0,24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Spacing="6" Margin="0,0,0,6">
                        <Border Height="1" Background="{StaticResource BcDividerBrush}" />
                        <TextBlock x:Name="RecentTitle" Text="최근 프로젝트" FontSize="{StaticResource FsCaption}" FontWeight="SemiBold"
                                   Foreground="{StaticResource BcTextSecondaryBrush}" />
                    </StackPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsRepeater ItemsSource="{x:Bind VM.RecentProjects, Mode=OneWay}">
                            <ItemsRepeater.Layout>
                                <StackLayout Spacing="2" />
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="vm:RecentProjectItem">
                                    <Button Tag="{x:Bind Path}" Click="OnRecentProjectClick"
                                            Background="Transparent" BorderThickness="0"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                            Padding="8,6" Opacity="{x:Bind MissingOpacity}">
                                        <StackPanel Spacing="1">
                                            <TextBlock Text="{x:Bind FileName}" FontSize="{StaticResource FsBody}"
                                                       Foreground="{StaticResource BcTextBrush}" />
                                            <TextBlock Text="{x:Bind Directory}" FontSize="{StaticResource FsCaptionSmall}"
                                                       Foreground="{StaticResource BcTextSecondaryBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                    </ScrollViewer>
                </Grid>

            </Grid>

            <!-- 상단 프로젝트 바 / 본문 경계선 -->
            <Border Grid.ColumnSpan="2" VerticalAlignment="Top" Height="1" Background="{StaticResource BcDividerBrush}" />
            <!-- 레일 / 본문 경계선 -->
            <Border Grid.Column="1" HorizontalAlignment="Left" Width="1" Background="{StaticResource BcDividerBrush}" />
        </Grid>

        <!-- ════════ 하단 바(상태 바) ════════ -->
        <Grid Grid.Row="2" Background="{StaticResource BcRailBrush}" ColumnDefinitions="Auto,*,Auto,Auto" Padding="12,0">
            <Border Grid.ColumnSpan="4" VerticalAlignment="Top" Height="1" Background="{StaticResource BcDividerBrush}" />
            <Grid Grid.Column="0" />
            <TextBlock Grid.Column="1" Text="{x:Bind VM.StatusText, Mode=OneWay}" VerticalAlignment="Center"
                       FontSize="{StaticResource FsCaptionSmall}" Foreground="{StaticResource BcTextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
            <TextBlock Grid.Column="2" Text="{x:Bind VM.EtaText, Mode=OneWay}" VerticalAlignment="Center"
                       FontSize="{StaticResource FsCaptionSmall}" Margin="0,0,10,0" Foreground="{StaticResource BcTextSecondaryBrush}" />
            <ProgressBar Grid.Column="3" Width="120" VerticalAlignment="Center"
                         Value="{x:Bind VM.ProgressValue, Mode=OneWay}" Maximum="100"
                         Visibility="{x:Bind VM.IsBusy, Mode=OneWay}" />
        </Grid>
    </Grid>
</Window>
